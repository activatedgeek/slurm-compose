#!/usr/bin/env bash

##
# Generated via slurm-compose.
#

{% for arg in sbatch_argv %}
#SBATCH {{ arg }}
{% endfor %}

function maybe_sbatch_requeue {
    max_restarts={{ max_restarts }}
    if [[ (-n "${SLURM_JOB_ID}") && ($max_restarts -gt 0) ]]; then
        restarts=${SLURM_RESTART_COUNT:-0}

        if (( restarts < max_restarts )); then
            requeue_job_id="${SLURM_JOB_ID}"
            if [[ (-n "${SLURM_ARRAY_JOB_ID:-}") && (-n "${SLURM_ARRAY_TASK_ID:-}") ]]; then
                requeue_job_id="${SLURM_ARRAY_JOB_ID}_${SLURM_ARRAY_TASK_ID}"
            fi

            echo "[INFO] Requeueing sbatch job ${requeue_job_id} (attempt $(( restarts + 1 ))/${max_restarts})"
            if ! scontrol requeue "${requeue_job_id}"; then
                echo "[ERROR] Failed to requeue sbatch job ${requeue_job_id}."
            fi
        else
            echo "[ERROR] Max restarts (${max_restarts}) reached."
        fi
    fi
}

{% for k, v in env.items() %}
export {{ k }}="{{ v }}"
{% endfor %}

step_pids=()
{% for step in steps +%}
##
# Step {{ loop.index0 }}
#
{% for k, v in step.env.items() %}
export {{ k }}="{{ v }}"
{% endfor %}
{
STEP_ID={{ loop.index0 }}
{% if step.job_name is defined %}
STEP_NAME={{ step.job_name }}
{% endif %}
{% for k, v in step.local_env.items() %}
export {{ k }}="{{ v }}"
{% endfor %}

{{ step.args | trim }}
} & step_pids+=($!)

{% if not loop.last and step_delay is defined %}
sleep {{ step_delay }}
{% endif %}
{% endfor %}

## Wait for any step to finish, and terminate pids.
exit_code=0
wait -n "${step_pids[@]}" || exit_code=$?
for pid in "${step_pids[@]}"; do
    kill -TERM "$pid" 2>/dev/null || true
done
wait "${step_pids[@]}" 2>/dev/null || true

## Attempt requeue for non-zero exit codes.
if [[ $exit_code -ne 0 ]]; then
    maybe_sbatch_requeue
fi

exit $exit_code
