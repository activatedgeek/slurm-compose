#!/usr/bin/env bash

##
# Generated via slurm-compose.
#

{% for arg in sbatch_argv %}
#SBATCH {{ arg }}
{% endfor %}

step_pids=()

{% for step in steps %}
##
# Step {{ loop.index }}
#
{% for k, v in step.env %}
export {{ k }}="{{ v }}"
{% endfor %}

{{ step.argv | join(" ") }} & step_pids+=($!)

# unset {{ step.env.keys() | join(" ") }}

{% endfor %}
